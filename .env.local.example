# Copy this file to .env.local and fill in the values.
# Every variable here is SERVER-ONLY — do NOT prefix any with VITE_, or it would
# be inlined into the client bundle.

# --- GitHub ---------------------------------------------------------------

# Personal Access Token used server-side to call the GitHub API. A fine-grained
# token with read-only public access is enough (no scopes required for public
# follower data). Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=

# OAuth App credentials, so users can sign in and unfollow on their own account.
# Create an OAuth App at https://github.com/settings/developers with the
# callback URL: <your-domain>/api/auth/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Random 32+ byte secret used to sign session cookies (HMAC).
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# --- Bluesky (AT Protocol OAuth) ------------------------------------------
# Only needed for Bluesky sign-in + unfollow. See SETUP-bluesky-oauth.md.

# Upstash Redis (free tier) — stores OAuth state/sessions across stateless
# serverless invocations. From the Upstash console → your DB → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ES256 private signing key (JWK, single line) for private_key_jwt. Generate with:
# node -e "const {JoseKey}=require('@atproto/oauth-client-node');JoseKey.generate(['ES256'],'bsky-key-1').then(k=>console.log(JSON.stringify(k.privateJwk)))"
BLUESKY_PRIVATE_KEY=

# Public origin of the deployment, no trailing slash (e.g. https://your-app.vercel.app).
# Must be stable in production — the OAuth client_id is derived from it.
PUBLIC_URL=
