# GitHub Personal Access Token used server-side to call the GitHub API.
# A fine-grained token with read-only public access is enough (no scopes
# required for public follower data). Create one at:
# https://github.com/settings/tokens
#
# This is a SERVER-ONLY variable — do NOT prefix it with VITE_, or it would be
# inlined into the client bundle.
GITHUB_TOKEN=

# GitHub OAuth App credentials, used so users can sign in and unfollow on their
# own account. Create an OAuth App at https://github.com/settings/developers
# with the callback URL: <your-domain>/api/auth/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Random 32+ byte secret used to sign session cookies (HMAC).
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
